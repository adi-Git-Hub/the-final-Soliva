NODE_ENV=development
PORT=5000
MONGO_URI=your_mongodb_connection_string

# JWT / cookie
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=30d
COOKIE_EXPIRE=30

# CORS allowlist — comma-separated origins. Include every dev port the real
# frontend (TanStack Start / Vite / Cloudflare preview) may bind to.
FRONTEND_URL=http://localhost:5173,http://localhost:3000,http://localhost:8080,http://localhost:8083

# OTP expiry in minutes — read by services/authService.js for registration
# and forgot-password flows. Without this, OTP expiry computes NaN ms.
OTP_EXPIRE=10

# Redis (BullMQ). If unreachable, background workers are skipped (see server.js).
REDIS_HOST=localhost
REDIS_PORT=6379

# SMTP (Nodemailer). Leave blank in dev unless you want real emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Soliva <no-reply@soliva.example>

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret