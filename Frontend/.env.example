# Frontend env — copy to .env and adjust per environment.

# Backend API base URL (no trailing slash). Backend listens on PORT=5000 by default.
VITE_API_URL=http://localhost:5000/api/v1

# Toggle mock API. Phase 3 wired the real backend, so default is "false".
# Flip to "true" temporarily if you want to develop the editorial UI without
# the backend running — the mock data lives in src/lib/mock-data.ts.
VITE_USE_MOCK_API=false

# Razorpay
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# Firebase (Google sign-in). Public client keys — Firebase console → Project
# settings → General → Your apps (Web). Leave blank to keep the button inert.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
